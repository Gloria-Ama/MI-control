{
  "expo": {
    "name": "MI Control",
    "slug": "mobile",
    "owner": "gloriaama",
    "version": "1.0.0",
    "description": "Application de gestion d'église — Meta Intimacy Church",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "micontrol",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.metaintimacy.micontrol",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Utilisé pour scanner les QR codes de présence et prendre des photos de profil.",
        "NSPhotoLibraryUsageDescription": "Utilisé pour choisir des photos de profil et des pièces jointes.",
        "NSMicrophoneUsageDescription": "Requis pour l'accès à la caméra."
      }
    },
    "android": {
      "package": "com.metaintimacy.micontrol",
      "adaptiveIcon": {
        "backgroundColor": "#07074C",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07074C",
          "image": "./assets/images/splash.png",
          "imageWidth": 400,
          "android": {
            "image": "./assets/images/splash.png",
            "imageWidth": 300
          }
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "MI Control utilise la caméra pour scanner les QR codes de présence."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MI Control accède à vos photos pour les photos de profil et pièces jointes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cbe4e8b4-6c5e-40f1-9fd6-9203d8811698"
      }
    }
  }
}